    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.1.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.20.2",
    "eslint-plugin-n": "^17.2.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
